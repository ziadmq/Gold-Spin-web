{
  "entities": {
    "Prize": {
      "title": "Prize",
      "description": "A prize configuration displayed on the fortune wheel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "probability": { "type": "number" },
        "color": { "type": "string" },
        "textColor": { "type": "string" },
        "status": { "type": "string", "enum": ["نشط", "غير نشط"] },
        "isGoldGradient": { "type": "boolean" },
        "cost": { "type": "number" }
      },
      "required": ["id", "label", "probability", "color", "textColor", "status"]
    },
    "AccessRequest": {
      "title": "AccessRequest",
      "description": "A request made by a visitor to obtain permission to spin the wheel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "type": "string", "enum": ["مقبول", "قيد الانتظار", "مرفوض"] },
        "requestDate": { "type": "string" },
        "position": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "purpose", "status", "requestDate"]
    },
    "DashboardStats": {
      "title": "DashboardStats",
      "description": "Global statistics of the wheel payouts and gold distribution",
      "type": "object",
      "properties": {
        "totalDistributed": { "type": "number" },
        "increasePercentage": { "type": "number" }
      },
      "required": ["totalDistributed", "increasePercentage"]
    },
    "WinRecord": {
      "title": "WinRecord",
      "description": "A ledger record specifying when a user spun and won a prize",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "prizeLabel": { "type": "string" },
        "valueAssumed": { "type": "number" },
        "winDate": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" }
      },
      "required": ["id", "email", "displayName", "prizeLabel", "valueAssumed", "winDate"]
    }
  },
  "firestore": {
    "prizes": {
      "schema": "Prize",
      "description": "Collections of prizes for the dashboard wheel"
    },
    "accessRequests": {
      "schema": "AccessRequest",
      "description": "List of access authorization requests from Google-authenticated luxury users"
    },
    "stats": {
      "schema": "DashboardStats",
      "description": "Global settings card representing value metrics and distribution indicators"
    },
    "wins": {
      "schema": "WinRecord",
      "description": "Spin winner history to capture payouts audit-trail"
    }
  }
}
